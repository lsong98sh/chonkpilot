{
  "description": "Release a mouse button. Example: {\"button\": \"left\"}",
  "name": "web_mouse_up",
  "parameters": {
    "type": "object",
    "properties": {
      "button": {
        "type": "string",
        "description": "Mouse button to release"
      },
      "modifiers": {
        "type": "array",
        "description": "Keyboard modifiers"
      },
      "browser_id": {
        "type": "string",
        "description": "Browser instance ID (returned by web_start). If not specified and only one instance exists, that instance is used."
      }
    },
    "required": []
  }
}